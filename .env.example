# Environment configuration for Markdown to PDF Converter

# Application settings
APP_NAME=Markdown to PDF Converter
DEBUG=False

# File upload constraints (in bytes)
MAX_FILE_SIZE=5242880
MAX_MARKDOWN_LENGTH=500000

# CORS configuration (comma-separated list of origins, or * for all)
ALLOWED_ORIGINS=*

# PDF defaults
DEFAULT_PAGE_SIZE=A4
DEFAULT_MARGIN=2cm
DEFAULT_FONT_SIZE=12

# Temporary directory for processing
TEMP_DIR=/tmp
